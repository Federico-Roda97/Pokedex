# Auto detect text files and normalize line endings
* text=auto

# Force LF for web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# Images (binary, no modification)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary